// Datasource & generator
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Restaurant {
  id        String              @id @default(cuid())
  name      String
  timezone  String              @default("America/New_York")
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  staff     Staff[]
  menuItems MenuItem[]
  orders    Order[]
  inventory InventoryPurchase[]
  customers Customer[]
  shifts    Shift[]
}

model Staff {
  id           String     @id @default(cuid())
  name         String
  role         String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  restaurantId String
  shifts       Shift[]
  orders       Order[]
}

model Customer {
  id           String     @id @default(cuid())
  name         String
  email        String?    @unique
  phone        String?    @unique
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  restaurantId String
  orders       Order[]
}

model MenuItem {
  id           String      @id @default(cuid())
  name         String
  category     String
  price        Decimal     @db.Decimal(10, 2)
  cost         Decimal     @db.Decimal(10, 2)
  isActive     Boolean     @default(true)
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id])
  restaurantId String
  orderItems   OrderItem[]
  createdAt    DateTime    @default(now())
}

model Order {
  id           String      @id @default(cuid())
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id])
  restaurantId String
  customer     Customer?   @relation(fields: [customerId], references: [id])
  customerId   String?
  staff        Staff?      @relation(fields: [staffId], references: [id])
  staffId      String?
  status       OrderStatus @default(PLACED)
  subtotal     Decimal     @db.Decimal(12, 2)
  tax          Decimal     @db.Decimal(12, 2)
  discount     Decimal     @default(0) @db.Decimal(12, 2)
  total        Decimal     @db.Decimal(12, 2)
  serviceType  ServiceType @default(DINE_IN)
  placedAt     DateTime    @default(now())
  orderItems   OrderItem[]
}

model OrderItem {
  id         String   @id @default(cuid())
  order      Order    @relation(fields: [orderId], references: [id])
  orderId    String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  menuItemId String
  quantity   Int
  price      Decimal  @db.Decimal(10, 2)
  cost       Decimal  @db.Decimal(10, 2)
}

model InventoryPurchase {
  id           String     @id @default(cuid())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  restaurantId String
  itemName     String
  quantity     Float
  unitCost     Decimal    @db.Decimal(10, 2)
  purchasedAt  DateTime   @default(now())
}

model Shift {
  id            String     @id @default(cuid())
  staff         Staff      @relation(fields: [staffId], references: [id])
  staffId       String
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id])
  restaurantId  String
  startedAt     DateTime
  endedAt       DateTime?
  ordersHandled Int        @default(0)
  upsellRate    Float      @default(0)
}

model DailySalesSummary {
  id            String     @id @default(cuid())
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id])
  restaurantId  String
  date          DateTime
  sales         Decimal    @db.Decimal(12, 2)
  orders        Int
  avgTicket     Decimal    @db.Decimal(10, 2)
  profitMargin  Float
  cogs          Decimal    @db.Decimal(12, 2)
  inventoryCost Decimal    @db.Decimal(12, 2)
  createdAt     DateTime   @default(now())

  @@unique([restaurantId, date])
}

model HourlySalesSummary {
  id           String     @id @default(cuid())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  restaurantId String
  hourStart    DateTime
  sales        Decimal    @db.Decimal(12, 2)
  orders       Int
  createdAt    DateTime   @default(now())

  @@unique([restaurantId, hourStart])
}

model MenuItemPerformanceSummary {
  id           String     @id @default(cuid())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  restaurantId String
  date         DateTime
  menuItemId   String
  revenue      Decimal    @db.Decimal(12, 2)
  quantity     Int
  profit       Decimal    @db.Decimal(12, 2)
  marginRate   Float
  createdAt    DateTime   @default(now())

  menuItem MenuItem @relation(fields: [menuItemId], references: [id])
  @@index([restaurantId, date])
  @@unique([restaurantId, date, menuItemId])
}

enum OrderStatus {
  PLACED
  PAID
  CANCELLED
}

enum ServiceType {
  DINE_IN
  TAKEOUT
  DELIVERY
}
